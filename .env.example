# Copie ce fichier vers `.env` et remplis les valeurs (`.env` est ignoré par git).

# OpenRouter (agent cloud, embeddings, reformulation KPI, génération SQL si USE_LLM + LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY='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'

# Optionnel
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=openrouter/free
# OPENROUTER_CHAT_FALLBACK=openrouter/free

# Exiger une période (année / mois / plage) avant d'exécuter un KPI (défaut: true)
# KPI_REQUIRE_EXPLICIT_PERIOD=true

# Reformulation KPI quand le moteur de règles ne comprend pas (SELECT 1)
# KPI_REWRITE_LLM=true
# KPI_REWRITE_PROVIDER=auto
# KPI_REWRITE_OPENROUTER_MODEL=stepfun/step-3.5-flash:free

# Agent LangGraph
USE_AGENT=true
# Persistance checkpoint (défaut true). Avec false, le saver mémoire ne partage pas entre workers uvicorn : le 2e message (« 2025 ») peut perdre le KPI précédent.
# AGENT_PERSIST=true

# =========================
# Base de données (optionnel)
# =========================
# Par défaut : SQLite local (db/sonasid.db). Pour Azure Sonasid :
# DB_PROVIDER=azure
# AZURE_SQL_SERVER=sql-son-prd.database.windows.net
# AZURE_SQL_DB=son-db-prd
# AZURE_SQL_USER=sqladmin
# AZURE_SQL_PASSWORD=<mot de passe SQL Login>
# AZURE_SQL_ODBC_DRIVER=ODBC Driver 18 for SQL Server
# AZURE_SQL_PROFILE=sonasid
#
# Tables Sonasid (schéma port / navires — optionnel, pour mapping futur)
# AZURE_SQL_TABLE_NAVIRE=dbo.NAVIRE
# AZURE_SQL_TABLE_ARRIVAGE=dbo.ARRIVAGE
#
# CORS frontend Sonasid (port 5175)
# CORS_ORIGINS=http://localhost:5175,http://localhost:5173

# Génération SQL de secours
# USE_LLM=true
# LLM_PROVIDER=openrouter
