# Copie ce fichier vers `.env` et remplis les valeurs (`.env` est ignoré par git).

# Azure AI Foundry — 3 modèles entreprise (prioritaires dans l'UI, au-dessus d'OpenRouter)
# Clé partagée pour les deux endpoints ci-dessous (ne jamais committer la vraie clé)
AZURE_OPENAI_API_KEY=
# Kimi + DeepSeek (API compatible OpenAI v1)
AZURE_OPENAI_ENDPOINT=https://ymaftouh-9045-resource.services.ai.azure.com/openai/v1
AZURE_OPENAI_DEPLOYMENT_1=Kimi-K2.6
AZURE_OPENAI_LABEL_1=Kimi K2.6
AZURE_OPENAI_DEPLOYMENT_2=DeepSeek-V4-Pro
AZURE_OPENAI_LABEL_2=DeepSeek V4 Pro
# Grok (API Azure Inference /models)
AZURE_INFERENCE_ENDPOINT=https://ymaftouh-9045-resource.services.ai.azure.com/models
# AZURE_INFERENCE_API_KEY=   # optionnel si identique à AZURE_OPENAI_API_KEY
AZURE_INFERENCE_DEPLOYMENT=grok-4.3
AZURE_INFERENCE_LABEL=Grok 4.3

# OpenRouter (conservé — Trinity + Flash en secours)
OPENROUTER_API_KEY=
# OPENROUTER_CHAT_FALLBACK=openrouter/free
# OPENROUTER_MODEL_TRINITY=
# OPENROUTER_MODEL_FLASH=

# Modèle par défaut : kimi (Azure) si configuré, sinon trinity
# SONASID_DEFAULT_CHAT_MODEL=kimi
# SONASID_NARRATE_MODEL=kimi
# SONASID_CHAT_TEMPERATURE=0.35
# SONASID_NARRATE_TEMPERATURE=0.4
# Dictée vocale serveur (fallback micro) — Whisper via OpenRouter
# OPENROUTER_STT_MODEL=openai/whisper-large-v3
# RAG: fts (recherche plein texte) | embeddings | hybrid
RAG_MODE=fts
# Optionnel
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=arcee-ai/trinity-large-preview:free
DB_PROVIDER=
AZURE_SQL_SERVER=
AZURE_SQL_DB=
AZURE_SQL_USER=
# Renseigne le mot de passe Login (Azure Data Studio) :
AZURE_SQL_PASSWORD=
AZURE_SQL_ODBC_DRIVER=
AZURE_SQL_PROFILE=

CORS_ORIGINS=http://localhost:5175,http://localhost:5173,http://127.0.0.1:5175

# Exiger une période (année / mois / plage) avant d'exécuter un KPI (défaut: true)
# KPI_REQUIRE_EXPLICIT_PERIOD=true

# Reformulation KPI quand le moteur de règles ne comprend pas (SELECT 1)
KPI_REWRITE_LLM=
KPI_REWRITE_PROVIDER=
# KPI_REWRITE_OPENROUTER_MODEL=stepfun/step-3.5-flash:free

# Agent LangGraph
USE_AGENT=
# Persistance checkpoint (défaut true). Avec false, le saver mémoire ne partage pas entre workers uvicorn : le 2e message (« 2025 ») peut perdre le KPI précédent.
AGENT_PERSIST=

# Génération SQL de secours
USE_LLM=
LLM_PROVIDER=

# Auth (local + Microsoft SSO)
SESSION_SECRET=
LOCAL_AUTH_USERS_JSON=

AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_REDIRECT_URI=
# RBAC users directory (editable by non-devs)
# Point this to a shared Excel file (OneDrive/SharePoint/network share) in production.
RBAC_USERS_XLSX_PATH=/Users/info/Desktop/new_project/sonasid_project/backend/security/users.xlsx
# Columns supported (header row, case-insensitive):
# - For SSO mapping: email, role, enabled(optional)
# - For local login: username, code, display_name(optional), email(optional), role, enabled(optional)
VITE_API_BASE=http://localhost:8001
